<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="Caja.AbrirCajaController" style="-fx-background-color: #FAF6F0;" prefWidth="400" prefHeight="350">
    <VBox spacing="12" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>
        <Label text="Abrir / Cerrar Caja" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1B4332;"/>
        <Separator/>
        <Label fx:id="lblEstado" text="Estado: Verificando..." style="-fx-font-size: 14; -fx-text-fill: #333;"/>
        <Label fx:id="lblInfo" text="" style="-fx-font-size: 12; -fx-text-fill: #666;" wrapText="true"/>
        <Separator/>
        <VBox spacing="8" fx:id="panelApertura">
            <Label text="Monto de Apertura" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
            <TextField fx:id="txtMontoApertura" promptText="0.00" prefWidth="200"/>
        </VBox>
        <VBox spacing="8" fx:id="panelCierre">
            <Label text="Monto de Cierre" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
            <TextField fx:id="txtMontoCierre" promptText="0.00" prefWidth="200"/>
        </VBox>
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="btnAbrir" text="Abrir Caja" onAction="#abrir" prefWidth="150" prefHeight="38" style="-fx-background-color: #1B4332; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Button fx:id="btnCerrar" text="Cerrar Caja" onAction="#cerrar" prefWidth="150" prefHeight="38" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
        </HBox>
        <Label fx:id="lblError" text="" style="-fx-text-fill: #E74C3C; -fx-font-size: 12;" visible="false"/>
    </VBox>
</AnchorPane>
