<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="Caja.TicketController" style="-fx-background-color: white;" prefWidth="380" prefHeight="520">
    <VBox spacing="6" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        <Label fx:id="lblEmpresa" text="" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1B4332;" alignment="CENTER" maxWidth="Infinity"/>
        <Label fx:id="lblRuc" text="" style="-fx-font-size: 11; -fx-text-fill: #666;" alignment="CENTER" maxWidth="Infinity"/>
        <Label fx:id="lblDireccion" text="" style="-fx-font-size: 11; -fx-text-fill: #666;" alignment="CENTER" maxWidth="Infinity"/>
        <Label fx:id="lblTelefono" text="" style="-fx-font-size: 11; -fx-text-fill: #666;" alignment="CENTER" maxWidth="Infinity"/>
        <Separator/>
        <Label fx:id="lblComandaInfo" text="" style="-fx-font-size: 12; -fx-text-fill: #333;" wrapText="true"/>
        <Separator/>
        <Label text="DETALLE" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1B4332;" maxWidth="Infinity" alignment="CENTER"/>
        <VBox fx:id="vbItems" spacing="4"/>
        <Separator/>
        <HBox spacing="10">
            <Label fx:id="lblSubtotal" text="Subtotal: S/ 0.00" style="-fx-font-size: 12; -fx-text-fill: #333;" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10">
            <Label fx:id="lblTotal" text="TOTAL: S/ 0.00" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1B4332;" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10">
            <Label fx:id="lblFormaPago" text="" style="-fx-font-size: 12; -fx-text-fill: #333;"/>
        </HBox>
        <Separator/>
        <Label fx:id="lblEstado" text="" style="-fx-font-size: 12; -fx-text-fill: #1B4332; -fx-font-weight: bold;" alignment="CENTER" maxWidth="Infinity"/>
        <Label text="¡Gracias por su preferencia!" style="-fx-font-size: 11; -fx-text-fill: #999;" alignment="CENTER" maxWidth="Infinity"/>
        <HBox spacing="10" alignment="CENTER" VBox.vgrow="ALWAYS">
            <padding><Insets top="10"/></padding>
            <Button fx:id="btnImprimir" text="Imprimir" onAction="#imprimir" style="-fx-background-color: #1B4332; -fx-text-fill: white; -fx-font-size: 12;"/>
            <Button fx:id="btnCerrar" text="Cerrar" onAction="#cerrar" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 12;"/>
        </HBox>
    </VBox>
</AnchorPane>
