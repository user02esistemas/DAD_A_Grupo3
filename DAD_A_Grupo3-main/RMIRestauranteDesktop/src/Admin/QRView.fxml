<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.QRController">
    <top><Label text="Generador de QR - Mesas" styleClass="page-title"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <HBox spacing="8">
                <Button fx:id="btnGenerarTodos" text="Generar Todos" onAction="#generarTodos" styleClass="btn-primary"/>
                <Button fx:id="btnGuardarQR" text="Guardar QR Seleccionado" onAction="#guardarQR" styleClass="btn-secondary"/>
            </HBox>
            <HBox spacing="10" VBox.vgrow="ALWAYS">
                <TableView fx:id="tblDatos" prefWidth="500" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                        <TableColumn fx:id="colNumero" text="Número" prefWidth="70"/>
                        <TableColumn fx:id="colCapacidad" text="Capacidad" prefWidth="80"/>
                        <TableColumn fx:id="colSalon" text="Salón" prefWidth="150"/>
                        <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="120"/>
                    </columns>
                </TableView>
                <VBox spacing="8" alignment="CENTER" prefWidth="250" style="-fx-border-color: #ddd; -fx-border-width: 1; -fx-padding: 10;">
                    <Label text="Vista Previa QR" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                    <ImageView fx:id="imgQR" fitWidth="200" fitHeight="200" preserveRatio="true"/>
                    <Label fx:id="lblMesaSeleccionada" text="Seleccione una mesa"/>
                </VBox>
            </HBox>
            <Label fx:id="lblTotal" text="Total: 0 mesas"/>
        </VBox>
    </center>
</BorderPane>
