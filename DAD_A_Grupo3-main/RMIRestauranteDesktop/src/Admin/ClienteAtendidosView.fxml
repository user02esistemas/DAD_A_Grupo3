<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.ClienteAtendidosController">
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #E8E0D5; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <Label text="Clientes Atendidos" styleClass="page-title" style="-fx-padding: 0 0 4 0;"/>
            <Label text="Clientes que han registrado datos al abrir una comanda" style="-fx-text-fill: #636E72; -fx-font-size: 12;"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="12">
            <padding><Insets top="14" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre..." prefWidth="280" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnBuscar" text="Buscar" onAction="#buscar" styleClass="btn-primary"/>
                <Button fx:id="btnRefrescar" text="Refrescar" onAction="#cargarDatos" styleClass="btn-secondary"/>
            </HBox>
            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colApellido" text="Apellido" prefWidth="150"/>
                    <TableColumn fx:id="colDocumento" text="Documento" prefWidth="130"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="130"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                </columns>
            </TableView>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="lblTotal" text="Total: 0 clientes" style="-fx-text-fill: #636E72; -fx-font-size: 12;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblInfo" text="Datos opcionales registrados por el cliente al abrir comanda" style="-fx-text-fill: #B0ABA5; -fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
