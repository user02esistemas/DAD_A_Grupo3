<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.MesaController">
    <top><Label text="Gestión de Mesas" styleClass="page-title"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="12">
            <padding><Insets top="10" right="14" bottom="14" left="14"/></padding>
            <HBox spacing="8">
                <Button fx:id="btnNuevo" text="Nueva Mesa" onAction="#nuevo" styleClass="btn-primary"/>
                <Button fx:id="btnRefrescar" text="Refrescar" onAction="#cargarDatos" styleClass="btn-secondary"/>
            </HBox>
            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNumero" text="Número" prefWidth="80"/>
                    <TableColumn fx:id="colCapacidad" text="Capacidad" prefWidth="80"/>
                    <TableColumn fx:id="colSalon" text="Salón" prefWidth="150"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                    <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
                </columns>
            </TableView>
            <Label fx:id="lblTotal" text="Total: 0 mesas"/>
        </VBox>
    </center>
</BorderPane>
