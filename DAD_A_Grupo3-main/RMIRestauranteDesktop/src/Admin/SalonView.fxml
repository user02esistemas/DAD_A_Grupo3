<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.SalonController">
    <top><Label text="Gestión de Salones" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1B4332;"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <HBox spacing="8">
                <Button fx:id="btnNuevo" text="Nuevo Salon" onAction="#nuevo" style="-fx-background-color: #1B4332; -fx-text-fill: white;"/>
                <Button fx:id="btnRefrescar" text="Refrescar" onAction="#cargarDatos"/>
            </HBox>
            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250"/>
                    <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
                </columns>
            </TableView>
            <Label fx:id="lblTotal" text="Total: 0 salones"/>
        </VBox>
    </center>
</BorderPane>
