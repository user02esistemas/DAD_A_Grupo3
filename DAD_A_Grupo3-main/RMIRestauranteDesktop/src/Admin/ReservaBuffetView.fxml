<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.ReservaBuffetController">
    <top><Label text="Gestión de Reservas Buffet" styleClass="page-title"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <HBox spacing="8">
                <Button fx:id="btnNuevo" text="Nueva Reserva" onAction="#nuevo" styleClass="btn-primary"/>
                <Button fx:id="btnRefrescar" text="Refrescar" onAction="#cargarDatos"/>
            </HBox>
            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFecha" text="Fecha/Hora" prefWidth="160"/>
                    <TableColumn fx:id="colPersonas" text="Personas" prefWidth="80"/>
                    <TableColumn fx:id="colCliente" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                    <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
                </columns>
            </TableView>
            <Label fx:id="lblTotal" text="Total: 0 reservas"/>
        </VBox>
    </center>
</BorderPane>
