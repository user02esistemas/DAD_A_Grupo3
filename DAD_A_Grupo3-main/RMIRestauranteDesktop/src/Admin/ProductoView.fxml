<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.ProductoController">
    <top><Label text="Gestión de Productos" styleClass="page-title"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <HBox spacing="8">
                <TextField fx:id="txtBuscar" promptText="Buscar producto..." prefWidth="300"/>
                <Button fx:id="btnBuscar" text="Buscar" onAction="#buscar"/>
                <Button fx:id="btnNuevo" text="Nuevo" onAction="#nuevo" styleClass="btn-primary"/>
            </HBox>
            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                    <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
                </columns>
            </TableView>
            <HBox spacing="8" alignment="CENTER">
                <Label fx:id="lblTotal" text="Total: 0 productos"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
