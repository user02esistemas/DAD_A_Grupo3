<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.ConfigController">
    <top><Label text="Configuración del Sistema" styleClass="page-title"><BorderPane.margin><Insets top="10" left="10"/></BorderPane.margin></Label></top>
    <center>
        <VBox spacing="10" maxWidth="600">
            <padding><Insets top="10" right="20" bottom="20" left="20"/></padding>
            <Label text="Datos de la Empresa" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #5C4033;"/>
            <TextField fx:id="txtRuc" promptText="RUC"/>
            <TextField fx:id="txtRazonSocial" promptText="Razón Social"/>
            <TextField fx:id="txtDireccion" promptText="Dirección"/>
            <TextField fx:id="txtTelefono" promptText="Teléfono"/>
            <TextField fx:id="txtEmail" promptText="Email"/>
            <Label text="Configuración QR" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #5C4033;"/>
            <TextField fx:id="txtQrBaseUrl" promptText="URL base (ej: http://localhost:8080/RMIRestauranteWeb)"/>
            <TextField fx:id="txtQrSecret" promptText="Secreto para hash QR"/>
            <Button fx:id="btnGuardar" text="Guardar Cambios" onAction="#guardar" styleClass="btn-primary"/>
            <Label fx:id="lblStatus" text="" style="-fx-font-size: 13;"/>
        </VBox>
    </center>
</BorderPane>
