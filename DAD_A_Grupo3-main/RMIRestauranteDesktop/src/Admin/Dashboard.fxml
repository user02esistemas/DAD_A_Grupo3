<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="Admin.DashboardController" prefWidth="1024" prefHeight="700" style="-fx-background-color: #FAF6F0;">
    <top>
        <HBox style="-fx-background-color: #1B4332;" spacing="0" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Label text="&#x1F33F; Overo's - Administración" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="&#x1F504; Cerrar Sesión" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13;"/>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 2, 0);" prefWidth="220" spacing="4">
            <padding><Insets top="10" bottom="10" left="8" right="8"/></padding>
            <Button text="&#x1F4CA; Dashboard" onAction="#navigate" fx:id="btnDash" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F37D;&#xFE0F; Productos" onAction="#navigate" fx:id="btnProd" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F4E6; Presentaciones" onAction="#navigate" fx:id="btnPres" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F4CD; Mesas" onAction="#navigate" fx:id="btnMesas" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F3EA; Salones" onAction="#navigate" fx:id="btnSalon" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F464; Mozos" onAction="#navigate" fx:id="btnMozos" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F4CB; Clientes Atendidos" onAction="#navigate" fx:id="btnClientes" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F4C5; Reservas Buffet" onAction="#navigate" fx:id="btnReservas" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x1F3F7;&#xFE0F; QR Mesas" onAction="#navigate" fx:id="btnQR" maxWidth="Infinity" styleClass="sidebar-btn"/>
            <Button text="&#x2699;&#xFE0F; Configuración" onAction="#navigate" fx:id="btnConfig" maxWidth="Infinity" styleClass="sidebar-btn"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea">
            <Label text="Seleccione una opción del menú" style="-fx-text-fill: #636E72; -fx-font-size: 16;" alignment="CENTER"/>
        </StackPane>
    </center>
</BorderPane>
